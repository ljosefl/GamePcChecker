<Application x:Class="GamePcChecker.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GamePcChecker.App.Converters"
             ShutdownMode="OnMainWindowClose"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <conv:VerdictSeverityToBrushConverter x:Key="SeverityBrush" />
        <SolidColorBrush x:Key="BgWindow" Color="#FF1E1E1E" />
        <SolidColorBrush x:Key="BgCard" Color="#FF252526" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#FF3F3F46" />
        <SolidColorBrush x:Key="TextPrimary" Color="#FFE6E6E6" />
        <SolidColorBrush x:Key="TextMuted" Color="#FF9D9D9D" />
        <SolidColorBrush x:Key="Accent" Color="#FF0078D4" />
        <Style x:Key="H1" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>
        <Style x:Key="H2" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>
        <Style x:Key="Body" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1A8CFF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#FF2D2D30" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3E3E42" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
