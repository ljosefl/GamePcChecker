<Window x:Class="GamePcChecker.App.StressTest.StressTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        Title="Стресс-тест GPU (DirectX 11)"
        Width="720"
        Height="760"
        MinWidth="540"
        MinHeight="560"
        Background="{StaticResource BgWindow}"
        FontFamily="Segoe UI Variable, Segoe UI"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource H1}" Text="Стресс-тест (синтетика)" />
            <TextBlock Foreground="{StaticResource TextMuted}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Text="Непрерывная отрисовка Direct3D 11 + тяжёлый pixel shader на активном GPU (NVIDIA, AMD, Intel). Не замер игры. Следите за температурой, шумом и стабильностью; при перегреве нажмите «Стоп»." />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,12"
                Background="#FF0D0D0D"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="6">
            <wfi:WindowsFormsHost x:Name="FormsHost">
                <wf:Panel x:Name="DxPanel" BackColor="Black" />
            </wfi:WindowsFormsHost>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock x:Name="SensorLineText"
                       FontSize="12"
                       Foreground="{StaticResource TextMuted}"
                       TextWrapping="Wrap"
                       Text="Датчики: инициализация…" />
            <Border Margin="0,8,0,0"
                    Padding="8,6"
                    Background="#12000000"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid Height="112">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,4,0"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Text="FPS" />
                        <Border Grid.Column="1"
                                Background="#10000000"
                                CornerRadius="2"
                                ClipToBounds="True">
                            <Canvas x:Name="FpsChartCanvas"
                                    SizeChanged="OnChartCanvasSizeChanged">
                                <Polyline x:Name="FpsPolyline"
                                          Stroke="#FF4ADE80"
                                          StrokeThickness="1.5"
                                          SnapsToDevicePixels="True" />
                            </Canvas>
                        </Border>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,4,0"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Text="°C" />
                        <Border Grid.Column="1"
                                Background="#10000000"
                                CornerRadius="2"
                                ClipToBounds="True">
                            <Canvas x:Name="TempChartCanvas"
                                    SizeChanged="OnChartCanvasSizeChanged">
                                <Polyline x:Name="CpuTempPolyline"
                                          Stroke="#FF60A5FA"
                                          StrokeThickness="1.5" />
                                <Polyline x:Name="GpuTempPolyline"
                                          Stroke="#FFFBBF24"
                                          StrokeThickness="1.5" />
                            </Canvas>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
            <TextBlock Margin="0,6,0,0"
                       FontSize="11"
                       Foreground="{StaticResource TextMuted}"
                       Text="Легенда графика °C: CPU — голубой, GPU — янтарный. Мощность — только GPU (если драйвер отдаёт), не БП." />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextMuted}"
                           Text="Интенсивность GPU" />
                <Slider x:Name="IntensitySlider"
                        Grid.Column="1"
                        Margin="12,0"
                        Maximum="200"
                        Minimum="1"
                        TickFrequency="10"
                        IsSnapToTickEnabled="False"
                        Value="80" />
                <TextBlock x:Name="IntensityLabel"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource TextPrimary}"
                           Text="80" />
            </Grid>
            <CheckBox x:Name="CpuCheck"
                      Margin="0,0,0,8"
                      Foreground="{StaticResource TextPrimary}"
                      Content="Доп. нагрузка на CPU (все логические ядра)" />
            <CheckBox x:Name="VsyncCheck"
                      Foreground="{StaticResource TextPrimary}"
                      Content="Вертикальная синхронизация (ограничение FPS)" />
        </StackPanel>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="0" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center">
                <TextBlock x:Name="StatsText"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="13"
                           Text="Готов."
                           TextWrapping="Wrap" />
                <TextBlock x:Name="FpsText"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text=""
                           TextWrapping="Wrap" />
            </StackPanel>
            <Button x:Name="ToggleBtn"
                    Grid.Column="1"
                    MinWidth="140"
                    VerticalAlignment="Center"
                    Click="OnToggleClick"
                    Content="Старт"
                    Style="{StaticResource BtnPrimary}" />
        </Grid>
    </Grid>
</Window>
